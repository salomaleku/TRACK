# =============================================================================
# Launch Tracker — SERVER (Corvus private node)
# =============================================================================

ENVIRONMENT=server

# Primary stream: Yellowstone Geyser gRPC (recommended for Corvus)
STREAM_MODE=geyser
GRPC_ENDPOINT=http://fra.corvus-labs.io:10101
# Optional — only for dedicated endpoints that require header auth
# GRPC_X_TOKEN=

# HTTP RPC — only for getTransaction enrichment + backfill
RPC_ENDPOINT=http://fra.corvus-labs.io:8899
RPC_RPS_LIMIT=80
RPC_MAX_RETRIES=5

# WebSocket — fallback if STREAM_MODE=websocket
# WS_ENDPOINT=ws://fra.corvus-labs.io:8900

# Bot wallet(s) for BUY/SELL trade alerts (comma-separated)
MY_WALLETS=34V5EApKJP8XCoLGnQgf6NmAw7RSCZM8R9GJVikkSvqa
# Fallback SOL/USD when price API is unavailable
SOL_USD_PRICE=75

DEVS_FILE=data/devs.txt
DATABASE=data/launch_tracker.db

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Backfill: safety net only, NOT primary monitor
BACKFILL_ENABLED=true
BACKFILL_ON_START=false
BACKFILL_INTERVAL_MINUTES=10
BACKFILL_SIGNATURES_PER_DEV=2
BACKFILL_CONCURRENCY=3

# Max parallel getTransaction calls
TX_PROCESSOR_CONCURRENCY=8

LOG_LEVEL=INFO

WS_RECONNECT_BASE_SECONDS=1.0
WS_RECONNECT_MAX_SECONDS=60.0
WS_HEARTBEAT_SECONDS=30.0
WS_SUBSCRIPTION_BATCH_SIZE=20

DEVS_RELOAD_SECONDS=30.0
TX_QUEUE_SIZE=10000
EXPLORER_BASE=https://solscan.io/tx/
GMGN_TOKEN_BASE=https://gmgn.ai/sol/token/
AXIOM_TOKEN_BASE=https://axiom.trade/t/
