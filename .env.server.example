# =============================================================================
# Launch Tracker — SERVER (private node, 200 RPS)
# Copy to .env on your server
# =============================================================================

ENVIRONMENT=server

# Private node endpoints (replace with your node URLs)
WS_ENDPOINT=wss://your-private-node.example.com
RPC_ENDPOINT=https://your-private-node.example.com

# 200 RPS Starter tier — set explicitly or rely on ENVIRONMENT=server preset
RPC_RPS_LIMIT=200
RPC_MAX_RETRIES=3

DEVS_FILE=data/devs.txt
DATABASE=data/launch_tracker.db

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

BACKFILL_ENABLED=true
BACKFILL_INTERVAL_MINUTES=10
BACKFILL_SIGNATURES_PER_DEV=5
BACKFILL_CONCURRENCY=15

LOG_LEVEL=INFO

WS_RECONNECT_BASE_SECONDS=1.0
WS_RECONNECT_MAX_SECONDS=60.0
WS_HEARTBEAT_SECONDS=30.0
WS_SUBSCRIPTION_BATCH_SIZE=20

DEVS_RELOAD_SECONDS=30.0
TX_QUEUE_SIZE=10000
EXPLORER_BASE=https://solscan.io/tx/
