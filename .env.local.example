# =============================================================================
# Launch Tracker — LOCAL (backtest / dev on public RPC)
# Copy to .env for local development
# =============================================================================

ENVIRONMENT=local

# Public Helius or other RPC — use multiple keys for rotation
WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY_1
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_1
RPC_ENDPOINT_2=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_2
RPC_ENDPOINT_3=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_3

# Conservative limits for public RPC
RPC_RPS_LIMIT=10
RPC_MAX_RETRIES=3

DEVS_FILE=data/devs.txt
DATABASE=data/launch_tracker.db

TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

BACKFILL_ENABLED=true
BACKFILL_INTERVAL_MINUTES=10
BACKFILL_SIGNATURES_PER_DEV=3
BACKFILL_CONCURRENCY=2

LOG_LEVEL=INFO

WS_RECONNECT_BASE_SECONDS=1.0
WS_RECONNECT_MAX_SECONDS=60.0
WS_HEARTBEAT_SECONDS=30.0
WS_SUBSCRIPTION_BATCH_SIZE=20

DEVS_RELOAD_SECONDS=30.0
TX_QUEUE_SIZE=10000
EXPLORER_BASE=https://solscan.io/tx/
GMGN_TOKEN_BASE=https://gmgn.ai/sol/token/
AXIOM_TOKEN_BASE=https://axiom.trade/t/
