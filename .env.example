# =============================================================================
# Launch Tracker
# =============================================================================

# Environment: "local" (dev/backtest) or "server" (production private node)
# local  → RPC_RPS_LIMIT defaults to 10,  backfill concurrency 2
# server → RPC_RPS_LIMIT defaults to 200, backfill concurrency 15
ENVIRONMENT=local

# --- WebSocket (primary event source) ---
WS_ENDPOINT=
# Optional rotation slots (same provider or failover)
WS_ENDPOINT_2=
WS_ENDPOINT_3=

# --- RPC (transaction fetch + backfill only) ---
RPC_ENDPOINT=
RPC_ENDPOINT_2=
RPC_ENDPOINT_3=

# Rate limit — override presets if needed
# local:  10 RPS recommended (public Helius)
# server: 200 RPS for Starter private node
RPC_RPS_LIMIT=
RPC_MAX_RETRIES=3

# Developer wallet list — one per line
DEVS_FILE=data/devs.txt

# SQLite database path
DATABASE=data/launch_tracker.db

# Telegram bot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Backfill safety net (not primary monitoring)
BACKFILL_ENABLED=true
BACKFILL_INTERVAL_MINUTES=10
BACKFILL_SIGNATURES_PER_DEV=5
BACKFILL_CONCURRENCY=

# Logging
LOG_LEVEL=INFO

# WebSocket tuning
WS_RECONNECT_BASE_SECONDS=1.0
WS_RECONNECT_MAX_SECONDS=60.0
WS_HEARTBEAT_SECONDS=30.0
WS_SUBSCRIPTION_BATCH_SIZE=20

# Developer list hot-reload interval
DEVS_RELOAD_SECONDS=30.0

# Transaction processing queue size
TX_QUEUE_SIZE=10000

# Explorer link base for notifications
EXPLORER_BASE=https://solscan.io/tx/
GMGN_TOKEN_BASE=https://gmgn.ai/sol/token/
AXIOM_TOKEN_BASE=https://axiom.trade/t/
